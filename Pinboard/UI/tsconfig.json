{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": "src",
    "outDir": "build",
    "skipLibCheck": true
  },
  "include": ["src", "types"],
  "exclude": ["node_modules"]
}
